# Server port
PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster-host>/<dbname>?appName=<appName>
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxxxx.mongodb.net/?appName=Cluster0

# JWT secret — replace with a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=replace_this_with_a_very_long_random_secret_key
